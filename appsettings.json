{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SwipeLimits": {
    "DailySwipeLimit": 100,
    "DailyLikeLimit": 50
  },
  "Authentication": {
    "Keycloak": {
      "Authority": "http://localhost:8090/realms/DatingApp",
      "ClientId": "swipe-service",
      "Audience": "swipe-service",
      "RequireHttpsMetadata": false,
      "ValidIssuers": [
        "http://localhost:8090/realms/DatingApp",
        "http://127.0.0.1:8090/realms/DatingApp",
        "http://10.0.2.2:8090/realms/DatingApp"
      ],
      "Audiences": [
        "swipe-service",
        "yarp-gateway",
        "account"
      ]
    }
  },
  "SwipeBehavior": {
    "SuspiciousRightSwipeRatio": 0.7,
    "SuspiciousVelocity": 10,
    "SuspiciousStreakLength": 20,
    "ConsecutiveLikeLimit": 30,
    "CooldownMinutes": 15,
    "RapidSwipeThresholdSeconds": 3.0,
    "RecalcEveryNSwipes": 10,
    "RatioPenaltyWeight": 100,
    "VelocityPenaltyWeight": 3,
    "StreakPenaltyWeight": 1.5,
    "LowProfileThreshold": 30,
    "LowProfilePenalty": 15,
    "MessageBonusBoost": 10,
    "MessageBonusThreshold": 0.5,
    "BackgroundRecalcIntervalHours": 6,
    "MinRecentSwipesForRecalc": 10,
    "FlagThreshold": 30
  }
}
